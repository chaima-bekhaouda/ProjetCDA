{
  "openapi": "3.0.3",
  "info": {
    "title": "BookNest API",
    "version": "1.0.0",
    "description": "Documentation Swagger des routes principales de BookNest, de l'authentification et du catalogue de livres."
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Afficher la page d'accueil",
        "responses": {
          "200": {
            "description": "Page d'accueil avec la collection et les stats"
          }
        }
      }
    },
    "/login": {
      "get": {
        "summary": "Afficher le formulaire de connexion",
        "responses": {
          "200": {
            "description": "Formulaire de connexion"
          }
        }
      },
      "post": {
        "summary": "Se connecter",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "jane@example.com" },
                  "password": { "type": "string", "example": "secret" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Connexion réussie, redirection vers l'accueil"
          }
        }
      }
    },
    "/register": {
      "get": {
        "summary": "Afficher le formulaire d'inscription",
        "responses": {
          "200": {
            "description": "Formulaire d'inscription"
          }
        }
      },
      "post": {
        "summary": "Créer un compte",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "display_name"],
                "properties": {
                  "email": { "type": "string", "example": "jane@example.com" },
                  "password": { "type": "string", "example": "secret" },
                  "display_name": { "type": "string", "example": "Jane" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Compte créé avec succès"
          }
        }
      }
    },
    "/logout": {
      "get": {
        "summary": "Déconnecter l'utilisateur",
        "responses": {
          "303": {
            "description": "Déconnexion réussie"
          }
        }
      },
      "post": {
        "summary": "Déconnecter l'utilisateur",
        "responses": {
          "303": {
            "description": "Déconnexion réussie"
          }
        }
      }
    },
    "/dashboard": {
      "get": {
        "summary": "Afficher le tableau de bord",
        "responses": {
          "200": {
            "description": "Vue du tableau de bord"
          }
        }
      }
    },
    "/books": {
      "get": {
        "summary": "Lister les livres de l'utilisateur",
        "responses": {
          "200": {
            "description": "Liste des livres"
          }
        }
      },
      "post": {
        "summary": "Créer un nouveau livre",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["title", "author"],
                "properties": {
                  "title": { "type": "string", "example": "Le Petit Prince" },
                  "author": { "type": "string", "example": "Antoine de Saint-Exupéry" },
                  "year": { "type": "integer", "example": 1943 },
                  "pages": { "type": "integer", "example": 96 },
                  "genre": { "type": "string", "example": "Classique" },
                  "status": { "type": "string", "example": "to_read" },
                  "notes": { "type": "string", "example": "À relire" },
                  "cover": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Livre créé avec succès"
          }
        }
      }
    },
    "/books/create": {
      "get": {
        "summary": "Afficher le formulaire de création d'un livre",
        "responses": {
          "200": {
            "description": "Formulaire de création"
          }
        }
      }
    },
    "/books/delete": {
      "post": {
        "summary": "Supprimer un livre",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["book_id"],
                "properties": {
                  "book_id": { "type": "string", "example": "123e4567-e89b-12d3-a456-426614174000" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Livre supprimé"
          }
        }
      }
    },
    "/authors": {
      "get": {
        "summary": "Afficher la page des auteurs",
        "responses": {
          "200": {
            "description": "Vue auteurs"
          }
        }
      }
    },
    "/loans": {
      "get": {
        "summary": "Afficher la page des emprunts",
        "responses": {
          "200": {
            "description": "Vue emprunts"
          }
        }
      }
    },
    "/reading-sessions": {
      "get": {
        "summary": "Afficher la page des séances de lecture",
        "responses": {
          "200": {
            "description": "Vue séances"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Afficher la page des utilisateurs",
        "responses": {
          "200": {
            "description": "Vue utilisateurs"
          }
        }
      }
    },
    "/db-test": {
      "get": {
        "summary": "Vérifier l'accès à la base de données",
        "responses": {
          "200": {
            "description": "Réponse de test"
          }
        }
      }
    }
  }
}